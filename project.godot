; Engine configuration file — Awakening Brochacho
; Godot 4.6 | Internal res 320×240 | Nearest-neighbor | Integer scale
; Edit via the Godot editor UI for safety; manual edits documented here.

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Awakening Brochacho"
config/description="A charming retro top-down pixel-art RPG."
run/main_scene="res://scenes/main/Main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://assets/sprites/ui/icon.png"

[autoload]

GameManager="*res://scripts/autoloads/GameManager.gd"
PartyManager="*res://scripts/autoloads/PartyManager.gd"
StoryManager="*res://scripts/autoloads/StoryManager.gd"
AudioManager="*res://scripts/autoloads/AudioManager.gd"
SceneManager="*res://scripts/autoloads/SceneManager.gd"

[display]

; 320×240 internal — scales to 640×480, 960×720, 1280×960 exactly (integer steps).
; "canvas_items" stretch mode + "keep" aspect = pixel-perfect on any monitor.
window/size/viewport_width=320
window/size/viewport_height=240
window/size/window_width_override=960
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"
; Integer scale prevents sub-pixel blurring on non-integer monitor sizes.
window/stretch/scale_mode="integer"

