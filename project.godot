[layer_names]

; Collision layers — keep these stable; changing them breaks existing scenes.
2d_physics/layer_1="world"
2d_physics/layer_2="player"
2d_physics/layer_3="enemies"
2d_physics/layer_4="items"
2d_physics/layer_5="triggers"

[physics]

; 60 Hz physics matches our 60 fps target and keeps movement deterministic.
common/physics_ticks_per_second=60

[rendering]

; Nearest-neighbor (0) = hard pixel edges — the classic retro look.
; Linear (1) would blur sprites; never use that here.
textures/canvas_textures/default_texture_filter=0
renderer/rendering_method.mobile="gl_compatibility"

[gdscript]

; Treat type-inference warnings as errors so Variant bugs surface at parse time.
warnings/untyped_declaration=2
warnings/inferred_declaration=2
warnings/unsafe_property_access=1
warnings/unsafe_method_access=1
